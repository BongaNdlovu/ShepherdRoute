{
  "name": "ShepherdRoute",
  "short_name": "ShepherdRoute",
  "description": "The follow-up pathway for churches that care.",
  "start_url": "/dashboard",
  "scope": "/",
  "display": "standalone",
  "background_color": "#f7f3eb",
  "theme_color": "#f7f3eb",
  "orientation": "portrait-primary",
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/shepherd-logo.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Contacts",
      "url": "/contacts",
      "description": "Open the contact dashboard"
    },
    {
      "name": "Create Event",
      "url": "/events/new",
      "description": "Create a QR registration event"
    }
  ]
}
